# Mithqal — environment variables
# Copy this file to .env and fill in real values. Never commit .env.

# ---- Database (SQLite) ----
DATABASE_URL=file:/home/z/my-project/db/custom.db

# ---- NextAuth (Admin console authentication) ----
# Generate with: openssl rand -hex 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ---- Operator account (env-defined — no user table) ----
ADMIN_EMAIL=coo@mithqal.io
# scrypt hash of the operator password, format: saltHex:hashHex
# Generate with:
#   node -e "const {scryptSync,randomBytes}=require('crypto');const p=process.argv[1];const s=randomBytes(16);const h=scryptSync(p,s,64);console.log(s.toString('hex')+':'+h.toString('hex'))" 'YOUR_PASSWORD'
ADMIN_PASSWORD_HASH=

# ---- Email notifications (Formation Committee submissions → operator) ----
ADMIN_NOTIFY_EMAIL=meltonsy@icloud.com
# SMTP — uncomment and set to enable real email delivery (currently logs to console)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="Mithqal <noreply@mithqal.io>"
